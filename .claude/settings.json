{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": false,
  "defaultMode": "default",
  "disableBypassPermissionsMode": "disable",
  "permissions": {
    "deny": [
      "Read(/.env)",
      "Read(/.env.*)",
      "Read(/secrets/**)",
      "Read(/.claude/settings.local.json)",
      "Read(/CLAUDE.local.md)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(rm *)",
      "Edit(/governance/**)"
    ]
  }
}
